<nav class="customer-nav">
    <div class="nav-brand">SHARETEA</div>
    <div class="nav-links">
        <a href="/customer">Menu</a>
        <a href="/customer/cart">Cart</a>
        <a href="/customer/checkout">Checkout</a>
        <button id="magnifier-toggle" class="btn-secondary">Magnifier: <span id="toggle-status">OFF</span></button>
        <button id="translate-btn" class="btn-secondary" onclick="toggleTranslate()">Español</button>
    </div>
</nav>
<script>
    var isSpanish = false;
    var originalTexts = [];

    function toggleTranslate() {
        if (isSpanish) {
            restoreOriginal();
            return;
        }
        translateToSpanish();
    }

    function restoreOriginal() {
        originalTexts.forEach(function(item) {
            item.el.textContent = item.text;
        });
        document.getElementById('translate-btn').textContent = 'Español';
        isSpanish = false;
    }

    function translateToSpanish() {
        var elements = document.querySelectorAll('#page-content h1, #page-content h2, #page-content h3, #page-content p, #page-content a, #page-content button, #page-content label, #page-content option, .modal-box h2, .modal-box p, .modal-box label, .modal-box option, .modal-box button');
        originalTexts = [];

        elements.forEach(function(el) {
            if (el.children.length === 0 || el.tagName === 'BUTTON' || el.tagName === 'OPTION') {
                var text = el.textContent.trim();
                if (text && text !== '' && !text.match(/^\$[\d.]+$/)) {
                    originalTexts.push({ el: el, text: el.textContent });
                }
            }
        });

        if (originalTexts.length === 0) return;

        document.getElementById('translate-btn').textContent = '...';

        var batches = [];
        var current = [];
        var currentLen = 0;

        originalTexts.forEach(function(item) {
            var addition = item.text.trim().length + 4;
            if (currentLen + addition > 450 && current.length > 0) {
                batches.push(current.slice());
                current = [];
                currentLen = 0;
            }
            current.push(item.text.trim());
            currentLen += addition;
        });
        if (current.length > 0) batches.push(current);

        var allTranslated = [];
        var batchIndex = 0;

        function nextBatch() {
            if (batchIndex >= batches.length) {
                var i = 0;
                originalTexts.forEach(function(item) {
                    if (i < allTranslated.length) {
                        item.el.textContent = allTranslated[i];
                    }
                    i++;
                });
                document.getElementById('translate-btn').textContent = 'English';
                isSpanish = true;
                return;
            }

            var combined = batches[batchIndex].join(' || ');
            var url = 'https://api.mymemory.translated.net/get?q=' + encodeURIComponent(combined) + '&langpair=en|es';

            fetch(url)
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    var parts = data.responseData.translatedText.split(' || ');
                    parts.forEach(function(p) { allTranslated.push(p.trim()); });
                    batchIndex++;
                    nextBatch();
                })
                .catch(function(err) {
                    console.error('Translation error:', err);
                    document.getElementById('translate-btn').textContent = 'Español';
                    alert('Translation failed. Please try again.');
                });
        }

        nextBatch();
    }
</script>
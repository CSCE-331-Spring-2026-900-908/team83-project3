<html>
    <head>
        <title><%= lang === 'es' ? 'Pagar' : 'Checkout' %></title>
        <link rel="stylesheet" href="/customer/customer.css">
    </head>
    <body>
    <%- include('../partials/navigation-customer', { lang: lang }) %>

    <main class="content-wrapper">
        <h1 class="page-title"><%= lang === 'es' ? '¿Cómo desea pagar?' : 'How would you like to pay?' %></h1>

        <div class="payment-options">
            <div class="payment-card" onclick="submitOrder()">
                <h2><%= lang === 'es' ? 'Pagar en Caja' : 'Pay at Counter' %></h2>
                <p><%= lang === 'es' ? 'Haga su pedido y pague con el cajero' : 'Place your order and pay with the cashier' %></p>
            </div>
            <div class="payment-card" onclick="submitOrder()">
                <h2><%= lang === 'es' ? 'Pagar con Tarjeta' : 'Pay with Card' %></h2>
                <p><%= lang === 'es' ? 'Deslice o toque su tarjeta' : 'Swipe or tap your card at the kiosk' %></p>
            </div>
        </div>
    </main>

    <script>
        var lang = '<%= lang %>';

        function submitOrder() {
            var cart = JSON.parse(localStorage.getItem('customer-cart') || '[]');

            if (cart.length === 0) {
                alert(lang === 'es' ? '¡Tu carrito está vacío!' : 'Your cart is empty!');
                return;
            }

            fetch('/api/customer-checkout', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ items: cart })
            })
            .then(function(res) {
                if (res.ok) {
                    localStorage.removeItem('customer-cart');
                    window.location.href = '/customer/order-confirmation?lang=' + lang;
                } else {
                    alert(lang === 'es' ? 'Algo salió mal.' : 'Something went wrong. Please try again.');
                }
            })
            .catch(function(err) {
                console.error(err);
                alert(lang === 'es' ? 'No se pudo hacer el pedido.' : 'Could not place order. Please try again.');
            });
        }
    </script>
    </body>
</html>
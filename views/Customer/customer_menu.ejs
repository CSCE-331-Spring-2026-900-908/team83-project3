<html>
    <head>
        <title>Menu</title>
        <link rel="stylesheet" href="/customer/customer.css">
        <style>
            .modal-overlay {
                display: none;
                position: fixed;
                top: 0; left: 0; right: 0; bottom: 0;
                background: rgba(0,0,0,0.5);
                z-index: 1000;
                justify-content: center;
                align-items: center;
            }
            .modal-overlay.active {
                display: flex;
            }
            .modal {
                background: white;
                border-radius: 12px;
                padding: 24px;
                max-width: 400px;
                width: 90%;
                box-shadow: 0 4px 20px rgba(0,0,0,0.3);
            }
            .modal h2 {
                margin-top: 0;
                font-size: 20px;
            }
            .modal h3 {
                font-size: 15px;
                margin-bottom: 6px;
                color: #333;
            }
            .customization-group {
                margin-bottom: 16px;
            }
            .customization-group label {
                display: block;
                padding: 6px 0;
                cursor: pointer;
                font-size: 14px;
            }
            .customization-group input[type="radio"],
            .customization-group input[type="checkbox"] {
                margin-right: 8px;
            }
            .modal-actions {
                display: flex;
                justify-content: flex-end;
                gap: 10px;
                margin-top: 18px;
            }
            .modal-actions button {
                padding: 8px 18px;
                border: none;
                border-radius: 6px;
                cursor: pointer;
                font-size: 14px;
            }
            .btn-cancel {
                background: #ccc;
                color: #333;
            }
            .btn-add {
                background: #500000;
                color: white;
            }
            .btn-add:hover { background: #700000; }
        </style>
    </head>
    <body>
    <%- include('../partials/navigation-customer') %>

    <main class="content-wrapper">
        <h1 class="page-title">Menu</h1>

        <div class="menu-grid">
            <% if (menu.length === 0) { %>
                <p>No menu items available.</p>
            <% } else { %>
                <% menu.forEach(item => { %>
                    <div class="menu-card">
                        <div class="img-placeholder"></div>
                        <h3><%= item.item_name %></h3>
                        <p>$<%= Number(item.cost).toFixed(2) %></p>
                        <button onclick="openCustomize('<%= item.item_name %>', '<%= item.cost %>')">Add to Cart</button>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </main>

    <!-- Customization Modal -->
    <div class="modal-overlay" id="customizeModal">
        <div class="modal">
            <h2>Customize: <span id="modal-item-name"></span></h2>

            <div class="customization-group">
                <h3>Milk</h3>
                <label><input type="checkbox" id="opt-milk"> Add Milk</label>
            </div>

            <div class="customization-group">
                <h3>Ice</h3>
                <label><input type="radio" name="ice" value="ice" checked> Ice</label>
                <label><input type="radio" name="ice" value="no ice"> No Ice</label>
            </div>

            <div class="customization-group">
                <h3>Toppings</h3>
                <label><input type="radio" name="topping" value="no boba" checked> No Boba</label>
                <label><input type="radio" name="topping" value="taro"> Taro</label>
                <label><input type="radio" name="topping" value="lychee jelly"> Lychee Jelly</label>
            </div>

            <div class="modal-actions">
                <button class="btn-cancel" onclick="closeCustomize()">Cancel</button>
                <button class="btn-add" onclick="confirmAdd()">Add to Cart</button>
            </div>
        </div>
    </div>

    <script>
        let currentItem = { name: '', price: 0 };

        function openCustomize(name, price) {
            currentItem = { name, price: Number(price) };
            document.getElementById('modal-item-name').textContent = name;

            // Reset selections
            document.getElementById('opt-milk').checked = false;
            document.querySelector('input[name="ice"][value="ice"]').checked = true;
            document.querySelector('input[name="topping"][value="no boba"]').checked = true;

            document.getElementById('customizeModal').classList.add('active');
        }

        function closeCustomize() {
            document.getElementById('customizeModal').classList.remove('active');
        }

        function confirmAdd() {
            const milk = document.getElementById('opt-milk').checked;
            const ice = document.querySelector('input[name="ice"]:checked').value;
            const topping = document.querySelector('input[name="topping"]:checked').value;

            const customizations = [];
            if (milk) customizations.push('Milk');
            customizations.push(ice === 'no ice' ? 'No Ice' : 'Ice');
            if (topping !== 'no boba') customizations.push(topping.charAt(0).toUpperCase() + topping.slice(1));

            const label = customizations.length > 0
                ? currentItem.name + ' (' + customizations.join(', ') + ')'
                : currentItem.name;

            let cart = JSON.parse(localStorage.getItem('customer-cart') || '[]');
            cart.push({ name: label, price: currentItem.price });
            localStorage.setItem('customer-cart', JSON.stringify(cart));

            closeCustomize();
        }
    </script>
    </body>
</html>
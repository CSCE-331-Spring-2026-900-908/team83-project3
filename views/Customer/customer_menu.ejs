<html>
    <head>
        <link id="theme-stylesheet" rel="stylesheet" href="/customer/customer.css">
        <link rel="stylesheet" href="/customer/magnifying.css">
    </head>
    <body>
    <div id="magnifier">
        <div id="magnifier-content"></div>
    </div>
    <div id="page-content">
    <%- include('../partials/navigation-customer') %>

    <main class="content-wrapper">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <button onclick="toggleTheme()" style="padding: 12px 24px; font-size: 16px; font-weight: bold; cursor: pointer; border: 2px solid currentColor; background: transparent; color: inherit;">
                Toggle Theme
            </button>
        </div>

        <div class="menu-grid">
            <% if (menu.length === 0) { %>
                <p>No menu items available.</p>
            <% } else { %>
                <% menu.forEach(item => { %>
                    <div class="menu-card">
                        <div class="img-placeholder"></div>
                        <h3><%= item.item_name %></h3>
                        <p class="menu-card-price">$<%= Number(item.cost).toFixed(2) %></p>
                        <p class="menu-card-ingredients"><%= item.ingredients %></p>
                        <button onclick="openCustomize('<%= item.item_name %>', '<%= item.cost %>', '<%= item.ingredients %>')">Add to Cart</button>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </main>
    </div>

    <div id="customize-modal" class="modal-overlay">
        <div class="modal-box">
            <h2 id="modal-title"></h2>
            <p class="modal-ingredients">Ingredients: <span id="modal-ingredients"></span></p>

            <div class="modal-field">
                <label>Milk Choice:</label>
                <select id="milk-choice">
                    <option value="2% Milk">2% Milk</option>
                    <option value="Whole Milk">Whole Milk</option>
                    <option value="Soy Milk">Soy Milk</option>
                    <option value="Oat Milk">Oat Milk</option>
                </select>
            </div>

            <div id="subs-container" class="modal-field"></div>

            <div class="modal-actions">
                <button class="btn-primary" onclick="confirmAdd()">Add to Cart</button>
                <button class="btn-secondary" onclick="closeCustomize()">Cancel</button>
            </div>
        </div>
    </div>

    <script>
        var currentItem = {};

        function openCustomize(name, price, ingredients) {
            currentItem = { name: name, price: Number(price), ingredients: ingredients };
            document.getElementById('modal-title').textContent = name;
            document.getElementById('modal-ingredients').textContent = ingredients;

            var parts = ingredients.split(',').map(function(s) { return s.trim(); });
            var container = document.getElementById('subs-container');
            container.innerHTML = '';

            parts.forEach(function(ing) {
                if (ing.toLowerCase().indexOf('milk') !== -1) return;

                var div = document.createElement('div');
                div.className = 'sub-option';
                var label = document.createElement('label');
                var cb = document.createElement('input');
                cb.type = 'checkbox';
                cb.value = ing;
                cb.className = 'sub-checkbox';
                label.appendChild(cb);
                label.appendChild(document.createTextNode(' No ' + ing));
                div.appendChild(label);
                container.appendChild(div);
            });

            document.getElementById('customize-modal').classList.add('active');
        }

        function closeCustomize() {
            document.getElementById('customize-modal').classList.remove('active');
        }

        function confirmAdd() {
            var milk = document.getElementById('milk-choice').value;
            var removed = [];
            var checkboxes = document.querySelectorAll('.sub-checkbox:checked');
            checkboxes.forEach(function(cb) { removed.push(cb.value); });

            var customizations = 'Milk: ' + milk;
            if (removed.length > 0) {
                customizations += ', No: ' + removed.join(', ');
            }

            var cart = JSON.parse(localStorage.getItem('customer-cart') || '[]');
            cart.push({
                name: currentItem.name,
                price: currentItem.price,
                customizations: customizations
            });
            localStorage.setItem('customer-cart', JSON.stringify(cart));

            closeCustomize();
            alert('Added to cart');
        }
        function toggleTheme() {
            const themeLink = document.getElementById('theme-stylesheet');
            const currentTheme = themeLink.getAttribute('href');
            const newTheme = currentTheme === '/customer/customer.css'
                ? '/customer/high-contrast-customer.css'
                : '/customer/customer.css';
            themeLink.setAttribute('href', newTheme);
            localStorage.setItem('kiosk-theme', newTheme);
        }
        document.addEventListener('DOMContentLoaded', () => {
            const savedTheme = localStorage.getItem('kiosk-theme');
            if (savedTheme) {
                document.getElementById('theme-stylesheet').setAttribute('href', savedTheme);
            }
        });
    </script>
    <script src="/customer/sliders.js"></script>
    <script src="/customer/magnify.js"></script>
    </body>
</html>
<html>
    <head>
        <title><%= lang === 'es' ? 'Menú' : 'Menu' %></title>
        <link rel="stylesheet" href="/customer/customer.css">
        <link rel="stylesheet" href="/customer/magnifying.css">
    </head>
    <body>
    <div id="magnifier">
        <div id="magnifier-content"></div>
    </div>
    <div id="page-content">
    <%- include('../partials/navigation-customer', { lang: lang }) %>

    <main class="content-wrapper">
        <h1 class="page-title"><%= lang === 'es' ? 'Menú' : 'Menu' %></h1>

        <div class="menu-grid">
            <% if (menu.length === 0) { %>
                <p><%= lang === 'es' ? 'No hay artículos disponibles.' : 'No menu items available.' %></p>
            <% } else { %>
                <% menu.forEach(item => { %>
                    <div class="menu-card">
                        <div class="img-placeholder"></div>
                        <h3><%= item.item_name %></h3>
                        <p class="menu-card-price">$<%= Number(item.cost).toFixed(2) %></p>
                        <p class="menu-card-ingredients"><%= item.ingredients %></p>
                        <button onclick="openCustomize('<%= item.item_name %>', '<%= item.cost %>', '<%= item.ingredients %>')"><%= lang === 'es' ? 'Agregar' : 'Add to Cart' %></button>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </main>
    </div>

    <div id="customize-modal" class="modal-overlay">
        <div class="modal-box">
            <h2 id="modal-title"></h2>
            <p class="modal-ingredients"><%= lang === 'es' ? 'Ingredientes:' : 'Ingredients:' %> <span id="modal-ingredients"></span></p>

            <div class="modal-field">
                <label><%= lang === 'es' ? 'Tipo de Leche:' : 'Milk Choice:' %></label>
                <select id="milk-choice">
                    <option value="2% Milk"><%= lang === 'es' ? 'Leche 2%' : '2% Milk' %></option>
                    <option value="Whole Milk"><%= lang === 'es' ? 'Leche Entera' : 'Whole Milk' %></option>
                    <option value="Soy Milk"><%= lang === 'es' ? 'Leche de Soya' : 'Soy Milk' %></option>
                    <option value="Oat Milk"><%= lang === 'es' ? 'Leche de Avena' : 'Oat Milk' %></option>
                </select>
            </div>

            <div id="subs-container" class="modal-field"></div>

            <div class="modal-actions">
                <button class="btn-primary" onclick="confirmAdd()"><%= lang === 'es' ? 'Agregar al Carrito' : 'Add to Cart' %></button>
                <button class="btn-secondary" onclick="closeCustomize()"><%= lang === 'es' ? 'Cancelar' : 'Cancel' %></button>
            </div>
        </div>
    </div>

    <script>
        var currentItem = {};
        var lang = '<%= lang %>';

        function openCustomize(name, price, ingredients) {
            currentItem = { name: name, price: Number(price), ingredients: ingredients };
            document.getElementById('modal-title').textContent = name;
            document.getElementById('modal-ingredients').textContent = ingredients;

            var parts = ingredients.split(',').map(function(s) { return s.trim(); });
            var container = document.getElementById('subs-container');
            container.innerHTML = '';

            parts.forEach(function(ing) {
                if (ing.toLowerCase().indexOf('milk') !== -1) return;

                var div = document.createElement('div');
                div.className = 'sub-option';
                var label = document.createElement('label');
                var cb = document.createElement('input');
                cb.type = 'checkbox';
                cb.value = ing;
                cb.className = 'sub-checkbox';
                label.appendChild(cb);
                label.appendChild(document.createTextNode((lang === 'es' ? ' Sin ' : ' No ') + ing));
                div.appendChild(label);
                container.appendChild(div);
            });

            document.getElementById('customize-modal').classList.add('active');
        }

        function closeCustomize() {
            document.getElementById('customize-modal').classList.remove('active');
        }

        function confirmAdd() {
            var milk = document.getElementById('milk-choice').value;
            var removed = [];
            var checkboxes = document.querySelectorAll('.sub-checkbox:checked');
            checkboxes.forEach(function(cb) { removed.push(cb.value); });

            var customizations = 'Milk: ' + milk;
            if (removed.length > 0) {
                customizations += ', ' + (lang === 'es' ? 'Sin: ' : 'No: ') + removed.join(', ');
            }

            var cart = JSON.parse(localStorage.getItem('customer-cart') || '[]');
            cart.push({
                name: currentItem.name,
                price: currentItem.price,
                customizations: customizations
            });
            localStorage.setItem('customer-cart', JSON.stringify(cart));

            closeCustomize();
            alert(lang === 'es' ? 'Agregado al carrito' : 'Added to cart');
        }
    </script>
    <script src="sliders.js"></script>
    <script src="/customer/magnify.js"></script>
    </body>
</html>
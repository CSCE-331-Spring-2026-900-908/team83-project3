<html>
    <head>
        <title>Menu</title>
        <link rel="stylesheet" href="/customer/customer.css">
        <link rel="stylesheet" href="/customer/magnifying.css">
    </head>
    <body>
    <div id ="magnifier">
        <div id="magnifier-content">
        </div>
    </div>
    <div id="page-content">
    <%- include('../partials/navigation-customer') %>
    <main class="content-wrapper">
        <h1 class="page-title">Menu</h1>

        <div class="menu-grid">
            <% if (menu.length === 0) { %>
                <p>No menu items available.</p>
            <% } else { %>
                <% menu.forEach(item => { %>
                    <div class="menu-card">
                        <div class="img-placeholder"></div>
                        <h3><%= item.item_name %></h3>
                        <p>$<%= Number(item.cost).toFixed(2) %></p>
                        <button onclick="addToCart('<%= item.item_name %>', '<%= item.cost %>')">Add to Cart</button>
                    </div>
                <% }); %>
            <% } %>
        </div>
    </main>
    </div>
    <script>
        function addToCart(name, price) {
            let cart = JSON.parse(localStorage.getItem('customer-cart') || '[]');
            cart.push({ name, price: Number(price) });
            localStorage.setItem('customer-cart', JSON.stringify(cart));
        }
    </script>
    <script src="sliders.js"></script>
    <script src="magnify.js"></script>
    </body>
</html>

<!DOCTYPE html>
<head>
    <title>Login</title>
    <style>
        body { font-family: Arial, sans-serif; display: flex; justify-content: center; align-items: center; min-height: 100vh; margin: 0; background: #f5f5f5; }
        .login-box { background: #fff; padding: 40px; border: 1px solid #ddd; text-align: center; max-width: 360px; width: 100%; }
        .login-box h1 { font-size: 24px; margin-bottom: 8px; }
        .login-box p { color: #666; font-size: 14px; margin-bottom: 24px; }
        .google-btn { display: inline-block; background: #4285F4; color: #fff; text-decoration: none; padding: 12px 24px; font-size: 14px; border: none; cursor: pointer; }
        .google-btn:hover { background: #357ae8; }
    </style>
</head>
<body>
    <div class="login-box">
        <h1>Boba Shop</h1>
        <p>Sign in to access the dashboard</p>
        <a href="/auth/google" class="google-btn">Sign in with Google</a>
    </div>
</body>
</html>
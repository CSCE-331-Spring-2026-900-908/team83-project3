<nav class="customer-nav">
    <div class="nav-brand">EIGHTTEATHREE TEA</div>
    <div class="nav-links">
        <a href="/customer">Menu</a>
        <a href="/customer/cart">Cart</a>
        <a href="/customer/checkout">Checkout</a>
        <div class="accessibility-controls">
            <label>Text <input type="range" id="text-size-slider" min="12" max="28" step="1" value="16"></label>
            <label>Buttons <input type="range" id="button-size-slider" min="0.8" max="2" step="0.1" value="1"></label>
        </div>
        <button id="magnifier-toggle" class="btn-secondary">Magnifier: <span id="toggle-status">OFF</span></button>
        <button id="theme-toggle" class="btn-secondary" onclick="openThemeModal()">Theme</button>
        <button id="translate-btn" class="btn-secondary" onclick="toggleTranslate()">Español</button>
        <span class="nav-weather"><span id="temp">--</span> | <span id="weather">--</span></span>
    </div>
</nav>

<!-- Theme Picker Modal -->
<div class="theme-modal-overlay" id="themeModal" style="display:none;">
    <div class="theme-modal-content">
        <h2>Choose a Theme</h2>
        <div class="theme-options">
            <button onclick="setTheme('')">Default</button>
            <button onclick="setTheme('theme-sunny')">Sunny</button>
            <button onclick="setTheme('theme-cloudy')">Cloudy</button>
            <button onclick="setTheme('theme-rainy')">Rainy</button>
            <button onclick="setTheme('theme-snowy')">Snowy</button>
            <button onclick="setTheme('theme-high-contrast')">High Contrast</button>
        </div>
        <button onclick="closeThemeModal()">Close</button>
    </div>
</div>

<!-- Chatbot Widget -->
<div id="chatbot-toggle" onclick="toggleChatbot()">💬</div>
<div id="chatbot-container">
    <div id="chatbot-header">
        <span>EightTeaThree Assistant</span>
        <button onclick="toggleChatbot()">✕</button>
    </div>
    <div id="chatbot-messages"></div>
    <div id="chatbot-input-area">
        <input type="text" id="chatbot-input" placeholder="Ask about our menu..." onkeydown="if(event.key==='Enter')sendChat()">
        <button onclick="sendChat()">Send</button>
    </div>
</div>

<script src="/customer/weather.js"></script>
<script>
    // Theme
    function openThemeModal() {
        document.getElementById('themeModal').style.display = 'flex';
    }
    function closeThemeModal() {
        document.getElementById('themeModal').style.display = 'none';
    }
    function setTheme(className) {
        document.body.className = className;
        localStorage.setItem('kiosk-theme', className);
        closeThemeModal();
    }
    document.addEventListener('DOMContentLoaded', function() {
        var saved = localStorage.getItem('kiosk-theme');
        if (saved) document.body.className = saved;
    });

    // Translate
    var isSpanish = false;
    var originalTexts = [];

    function toggleTranslate() {
        if (isSpanish) {
            restoreOriginal();
            return;
        }
        translateToSpanish();
    }

    function restoreOriginal() {
        originalTexts.forEach(function(item) {
            item.el.textContent = item.text;
        });
        document.getElementById('translate-btn').textContent = 'Español';
        isSpanish = false;
    }

    function translateToSpanish() {
        var elements = document.querySelectorAll('#page-content h1, #page-content h2, #page-content h3, #page-content p, #page-content a, #page-content button, #page-content label, #page-content option, .modal-box h2, .modal-box p, .modal-box label, .modal-box option, .modal-box button');
        originalTexts = [];

        elements.forEach(function(el) {
            if (el.children.length === 0 || el.tagName === 'BUTTON' || el.tagName === 'OPTION') {
                var text = el.textContent.trim();
                if (text && text !== '' && !text.match(/^\$[\d.]+$/)) {
                    originalTexts.push({ el: el, text: el.textContent });
                }
            }
        });

        var chunkSize = 10;
        var chunks = [];
        for (var i = 0; i < originalTexts.length; i += chunkSize) {
            chunks.push(originalTexts.slice(i, i + chunkSize));
        }

        var completed = 0;
        chunks.forEach(function(chunk, chunkIndex) {
            var textsToTranslate = chunk.map(function(item) { return item.text.trim(); });

            fetch('https://api.mymemory.translated.net/get?q=' + encodeURIComponent(textsToTranslate.join('\n')) + '&langpair=en|es')
                .then(function(res) { return res.json(); })
                .then(function(data) {
                    if (data.responseData && data.responseData.translatedText) {
                        var translations = data.responseData.translatedText.split('\n');
                        chunk.forEach(function(item, i) {
                            if (translations[i]) {
                                item.el.textContent = translations[i];
                            }
                        });
                    }
                    completed++;
                    if (completed === chunks.length) {
                        document.getElementById('translate-btn').textContent = 'English';
                        isSpanish = true;
                    }
                })
                .catch(function(err) {
                    console.error('Translation error on chunk ' + chunkIndex + ':', err);
                    completed++;
                });
        });
    }
    // Chatbot
    function toggleChatbot() {
        var container = document.getElementById('chatbot-container');
        var toggle = document.getElementById('chatbot-toggle');
        if (container.classList.contains('open')) {
            container.classList.remove('open');
            toggle.style.display = 'flex';
        } else {
            container.classList.add('open');
            toggle.style.display = 'none';
        }
    }

    var chatHistory = [];

    async function sendChat() {
        var input = document.getElementById('chatbot-input');
        var msg = input.value.trim();
        if (!msg) return;
        input.value = '';

        appendMessage('user', msg);
        chatHistory.push({ role: 'user', content: msg });

        appendMessage('assistant', '...');

        try {
            var res = await fetch('/api/chat', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ messages: chatHistory })
            });
            var data = await res.json();

            removeLastAssistant();

            if (data.reply) {
                appendMessage('assistant', data.reply);
                chatHistory.push({ role: 'assistant', content: data.reply });
            } else {
                appendMessage('assistant', 'Sorry, I couldn\'t get a response. Please try again.');
            }
        } catch (err) {
            removeLastAssistant();
            appendMessage('assistant', 'Sorry, I couldn\'t connect. Please try again.');
            console.error(err);
        }
    }

    function appendMessage(role, text) {
        var container = document.getElementById('chatbot-messages');
        var div = document.createElement('div');
        div.className = 'chat-msg chat-' + role;
        div.textContent = text;
        container.appendChild(div);
        container.scrollTop = container.scrollHeight;
    }

    function removeLastAssistant() {
        var container = document.getElementById('chatbot-messages');
        var msgs = container.querySelectorAll('.chat-assistant');
        if (msgs.length > 0) msgs[msgs.length - 1].remove();
    }
</script>
            <button class="btn-secondary" onclick="manualThemeSelect('theme-cloudy')">Cloudy</button>
            <button class="btn-secondary" onclick="manualThemeSelect('theme-rainy')">Rainy</button>
            <button class="btn-secondary" onclick="manualThemeSelect('theme-snowy')">Snowy</button>

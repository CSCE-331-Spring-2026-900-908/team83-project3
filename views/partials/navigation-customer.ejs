<nav class="customer-nav">
    <div class="nav-brand">SHARETEA</div>
    <div class="nav-links">
        <a href="/customer?lang=<%= lang %>"><%= lang === 'es' ? 'Menú' : 'Menu' %></a>
        <a href="/customer/cart?lang=<%= lang %>"><%= lang === 'es' ? 'Carrito' : 'Cart' %></a>
        <a href="/customer/checkout?lang=<%= lang %>"><%= lang === 'es' ? 'Pagar' : 'Checkout' %></a>
        <button id="magnifier-toggle" class="btn-secondary"><%= lang === 'es' ? 'Lupa' : 'Magnifier' %>: <span id="toggle-status">OFF</span></button>
        <% if (lang === 'es') { %>
            <a href="?lang=en" class="lang-toggle">English</a>
        <% } else { %>
            <a href="?lang=es" class="lang-toggle">Español</a>
        <% } %>
    </div>
    <div class="accessibility-controls">
        <label>Text Size: 
            <input type="range" id="text-size-slider" min="12" max="30" value="16">
        </label>
        <label>Button Size: 
            <input type="range" id="button-size-slider" min="0.5" max="2" step="0.1" value="1">
        </label>
    </div>
</nav>
<!DOCTYPE html>
<html>
<head>
    <title>Statistics</title>
    <link rel="stylesheet" href="/manager/manager.css">
</head>

<body>
    <%- include('../partials/navigation-manager') %>
    <h1>Statistics</h1>

    <!-- ===================== -->
    <!-- SALES REPORT SECTION -->
    <!-- ===================== -->
    <h2>Sales Report</h2>

    <label>Start Date:</label>
    <input type="date" id="salesStart">

    <label>End Date:</label>
    <input type="date" id="salesEnd">

    <button onclick="runSalesReport()">Generate Sales Report</button>

    <table id="salesTable" border="1">
        <tr>
            <th>Item</th>
            <th>Revenue</th>
        </tr>
    </table>

    <hr>

    <!-- ===================== -->
    <!-- PRODUCT USAGE SECTION -->
    <!-- ===================== -->
    <h2>Product Usage Report</h2>

    <label>Start Date:</label>
    <input type="date" id="usageStart">

    <label>End Date:</label>
    <input type="date" id="usageEnd">

    <button onclick="runProductUsage()">Generate Product Usage</button>

    <table id="usageTable" border="1">
        <tr>
            <th>Ingredient</th>
            <th>Times Used</th>
        </tr>
    </table>

    <script>
        // ============================
        // SALES REPORT
        // ============================
        async function runSalesReport() {
            const start = document.getElementById("salesStart").value;
            const end = document.getElementById("salesEnd").value;

            if (!start || !end) {
                alert("Please select both dates");
                return;
            }

            const res = await fetch(`/api/sales-report?start=${start}&end=${end}`);
            const data = await res.json();

            const table = document.getElementById("salesTable");
            table.innerHTML = "<tr><th>Item</th><th>Revenue</th></tr>";

            data.forEach(row => {
                table.innerHTML += `
                    <tr>
                        <td>${row.item_name}</td>
                        <td>$${Number(row.revenue).toFixed(2)}</td>
                    </tr>
                `;
            });
        }

        // ============================
        // PRODUCT USAGE REPORT
        // ============================
        async function runProductUsage() {
            const start = document.getElementById("usageStart").value;
            const end = document.getElementById("usageEnd").value;

            if (!start || !end) {
                alert("Please select both dates");
                return;
            }

            const res = await fetch(`/api/product-usage?start=${start}&end=${end}`);
            const data = await res.json();

            const table = document.getElementById("usageTable");
            table.innerHTML = "<tr><th>Ingredient</th><th>Times Used</th></tr>";

            data.forEach(row => {
                table.innerHTML += `
                    <tr>
                        <td>${row.ingredient_name}</td>
                        <td>${row.ingredient_usage}</td>
                    </tr>
                `;
            });
        }

        // ============================
        // AUTO-LOAD DEFAULT DATES
        // ============================
        window.onload = () => {
            const today = new Date().toISOString().slice(0, 10);
            const last30 = new Date(Date.now() - 30*24*60*60*1000)
                                .toISOString().slice(0, 10);

            document.getElementById("salesStart").value = last30;
            document.getElementById("salesEnd").value = today;

            document.getElementById("usageStart").value = last30;
            document.getElementById("usageEnd").value = today;
        };
    </script>

</body>
</html>

<!DOCTYPE html>
<html>
<head>
    <link href="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/main.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/fullcalendar@6.1.8/main.min.js"></script>
</head>

<body>
    <%- include('../partials/navigation-manager') %>
    <h1>Employee Scheduler</h1>

    <div id="calendar"></div>

    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const calendarEl = document.getElementById('calendar');

            const calendar = new FullCalendar.Calendar(calendarEl, {
                initialView: 'dayGridMonth',
                events: '/api/schedule',

                dateClick: function(info) {
                    const employee_id = prompt("Employee ID:");
                    const start = prompt("Start time (HH:MM):");
                    const end = prompt("End time (HH:MM):");

                    fetch('/api/schedule/add', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/json' },
                        body: JSON.stringify({
                            employee_id,
                            shift_date: info.dateStr,
                            start_time: start,
                            end_time: end
                        })
                    }).then(() => calendar.refetchEvents());
                },

                eventClick: function(info) {
                    if (confirm("Delete this shift?")) {
                        fetch('/api/schedule/delete', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ shift_id: info.event.id })
                        }).then(() => calendar.refetchEvents());
                    }
                }
            });

            calendar.render();
        });
    </script>
</body>
</html>

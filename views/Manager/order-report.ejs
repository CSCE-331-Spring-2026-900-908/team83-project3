<!DOCTYPE html>
<html>
<head>
    <title>Order Reports</title>
    <link rel="stylesheet" href="/manager/manager.css">

</head>

<body>
    <%- include('../partials/navigation-manager') %>

    <h1>Order Reports</h1>

    <label>Date:</label>
    <input type="date" id="reportDate">

    <label>Hour:</label>
    <select id="Hour">
    <% for (let h = 8; h <= 21; h++) { %>
        <option value="<%= h %>"><%= h %>:00</option>
    <% } %>
    </select>

    <button onclick="runXReport()">Run X Report</button>
    <button onclick="runZReport()">Run Z Report</button>
    <!-- Create table for X Report Data -->
    <h2>X Report</h2>
    <table id="xReportTable" border="1">
        <thead>
            <tr><th>Hour</th><th>Quantity</th><th>Subtotal</th></tr>
        </thead>
        <tbody id="xReportTableBody"></tbody>
    </table>


    <h2>Z Report</h2>
    <table id="zReportTable" border="1">
        <thead>
            <tr><th>Total Quantity</th><th>Total Sales</th></tr>
        </thead>
        <tbody id="zReportBody"></tbody>
    </table>

    <script>
    document.getElementById("reportDate").addEventListener("change", () => {
    document.getElementById("xReportTableBody").innerHTML = "";
    document.getElementById("zReportBody").innerHTML = "";
});

        // X Report Logic
        async function runXReport() {
            const date = document.getElementById("reportDate").value;
            const hour = Number(document.getElementById("Hour").value);

            const res = await fetch('/api/x-report', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ date, hour })
            });

            const data = await res.json();

            const tableBody = document.getElementById("xReportTableBody");
            tableBody.innerHTML = "";

            data.rows.forEach(r => {
                tableBody.innerHTML += `
                    <tr>
                        <td>${r.hour}</td>
                        <td>${r.quantity}</td>
                        <td>${r.subtotal}</td>
                    </tr>`;
            });
        }


        // Z Report Logic
        async function runZReport() {
            const date = document.getElementById("reportDate").value;

            const res = await fetch('/api/z-report', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ date })
            });

            const data = await res.json();

            document.getElementById("zReportBody").innerHTML = `
                <tr>
                    <td>${data.total_quantity}</td>
                    <td>$${data.total_sales}</td>
                </tr>
            `;
        }

    </script>
</body>
</html>

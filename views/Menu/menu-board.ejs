<html>
    <head>
        <title>Menu</title>
        <link rel="stylesheet" href="/menu/menu.css">
    </head>
    <body>
        <!-- Main Content -->
        <div id="page-content">
            <main class="content-wrapper">
                <div style="margin-bottom: 16px; text-align: center;">
                    <h1 class="page-title">Menu</h1>
                </div>
                <!-- Items Display -->
                <div class="menu-grid">
                    <% if (menu.length === 0) { %>
                        <p>No menu items available</p>
                    <% } else { %>
                        <% menu.forEach(item => { %>
                            <div class="menu-card">
                                <!--Displays the image associated with a drink's category-->
                                <img 
                                    src="/images/<%= item.category %>.png" 
                                    alt="<%= item.item_name %>" 
                                    class="menu-item-img"
                                    onerror="this.src='/images/default.png'"
                                >
                                <h3><%= item.item_name %></h3>
                                <p class="menu-card-price">$<%= Number(item.cost).toFixed(2) %></p>
                            </div>
                        <% }); %>
                    <% } %>
                </div>

        </div>
    </body>
</html>

<!DOCTYPE html>
<html>
    <head>
        <title>Create Order</title>
        <link rel="stylesheet" href="/Cashier/cashier.css">
    </head>
    <body>
        <!-- Navigation -->
        <%- include('../partials/navigation-cashier') %>
        <!-- Main Content -->
        <main class="content-wrapper-create-order">
            <h1 class="page-title">Menu</h1>
            <!-- Dynamic Menu Items Grid-->
            <section class="menu-grid">
                <% items.forEach(item => { %>
                    <!-- Display Item Name and Cost From DB-->
                    <div class="menu-item" onclick="openCustomize('<%= item.item_name %>', '<%= item.cost %>')">
                        <h3><%= item.item_name %></h3>
                        <p class="price">$<%= item.cost ? Number(item.cost).toFixed(2) : "0.00" %></p>
                    </div>
                <% }); %>
            </section> </main>
            <a href="/cart" class="floating-cart-button">View Cart (0 items)</a>

            <div class="modal-overlay" id="customizeModal">
                <div class="modal-box">
                    <h2>Customize: <span id="modal-item-name"></span></h2>

                    <div class="customization-group">
                        <h3>Milk</h3>
                        <label><input type="radio" name="milk" value="whole" checked> Whole</label>
                        <label><input type="radio" name="milk" value="2%"> 2%</label>
                        <label><input type="radio" name="milk" value="oat"> Oat</label>
                        <label><input type="radio" name="milk" value="soy"> Soy</label>
                        <label><input type="radio" name="milk" value="none"> No Milk</label>
                    </div>

                    <div class="customization-group">
                        <h3>Sugar Level</h3>
                        <label><input type="radio" name="sugar" value="30%"> 30%</label>
                        <label><input type="radio" name="sugar" value="60%"> 60%</label>
                        <label><input type="radio" name="sugar" value="90%"> 90%</label>
                        <label><input type="radio" name="sugar" value="100%" checked> 100%</label>
                        <label><input type="radio" name="sugar" value="120%"> 120%</label>
                    </div>

                    <div class="customization-group">
                        <h3>Temperature</h3>
                        <label><input type="radio" name="temp" value="cold" checked onchange="toggleIce()"> Cold</label>
                        <label><input type="radio" name="temp" value="hot" onchange="toggleIce()"> Hot</label>
                    </div>

                    <div class="customization-group" id="ice-group">
                        <h3>Ice Level</h3>
                        <label><input type="radio" name="ice" value="extra ice"> Extra Ice</label>
                        <label><input type="radio" name="ice" value="regular ice" checked> Regular Ice</label>
                        <label><input type="radio" name="ice" value="less ice"> Less Ice</label>
                        <label><input type="radio" name="ice" value="no ice"> No Ice</label>
                    </div>

                    <div class="customization-group">
                        <h3>Toppings ($1 each)</h3>
                        <label><input type="checkbox" name="topping" value="boba"> Boba</label>
                        <label><input type="checkbox" name="topping" value="taro"> Taro</label>
                        <label><input type="checkbox" name="topping" value="lychee jelly"> Lychee Jelly</label>
                    </div>

                    <div class="customization-group">
                        <h3>Quantity</h3>
                        <div style="display:flex;align-items:center;gap:12px;">
                            <button type="button" class="checkout-button" onclick="changeQty(-1)" style="width:36px;height:36px;font-size:1.2em;display:flex;align-items:center;justify-content:center;padding:0;">−</button>
                            <span id="item-qty" style="font-size:1.1em;font-weight:bold;min-width:20px;text-align:center;">1</span>
                            <button type="button" class="checkout-button" onclick="changeQty(1)" style="width:36px;height:36px;font-size:1.2em;display:flex;align-items:center;justify-content:center;padding:0;">+</button>
                        </div>
                    </div>

                    <div class="modal-actions">
                        <button id="cancel-btn" class="btn-secondary" onclick="closeCustomize()">Cancel</button>
                        <button class="btn-primary" onclick="confirmAdd()">Add to Cart</button>
                    </div>
                </div>
            </div>
            <script>
            let currentItem = { name: '', price: 0 };
            let itemQty = 1;

            function changeQty(delta) {
                itemQty = Math.max(1, itemQty + delta);
                document.getElementById('item-qty').textContent = itemQty;
            }

            function updateCartCount() {
                const cart = JSON.parse(localStorage.getItem('cart') || '[]');
                const count = cart.length;
                const cartBtn = document.querySelector('.floating-cart-button');
                if (cartBtn) {
                    cartBtn.textContent = `View Cart (${count} items)`;
                }
            }

            function getModal() {
                return document.getElementById('customizeModal');
            }

            function toggleIce() {
                var m = getModal();
                var temp = m.querySelector('input[name="temp"]:checked');
                var iceGroup = document.getElementById('ice-group');
                if (temp && temp.value === 'hot') {
                    iceGroup.classList.add('disabled');
                    m.querySelector('input[name="ice"][value="no ice"]').checked = true;
                } else {
                    iceGroup.classList.remove('disabled');
                    m.querySelector('input[name="ice"][value="regular ice"]').checked = true;
                }
            }

            function openCustomize(name, price) {
                currentItem = { name, price: Number(price) };
                var m = getModal();
                document.getElementById('modal-item-name').textContent = name;

                m.querySelector('input[name="milk"][value="whole"]').checked = true;
                m.querySelector('input[name="sugar"][value="100%"]').checked = true;
                m.querySelector('input[name="temp"][value="cold"]').checked = true;
                m.querySelector('input[name="ice"][value="regular ice"]').checked = true;
                m.querySelectorAll('input[name="topping"]').forEach(function(cb) { cb.checked = false; });
                document.getElementById('ice-group').classList.remove('disabled');

                itemQty = 1;
                document.getElementById('item-qty').textContent = 1;

                m.classList.add('active');
            }

            function closeCustomize() {
                getModal().classList.remove('active');
            }

            function confirmAdd() {
                var m = getModal();
                var milk = m.querySelector('input[name="milk"]:checked');
                var sugar = m.querySelector('input[name="sugar"]:checked');
                var temp = m.querySelector('input[name="temp"]:checked');
                var ice = m.querySelector('input[name="ice"]:checked');
                var toppings = Array.from(m.querySelectorAll('input[name="topping"]:checked'));
                var toppings_amount = toppings.length;

                if (!milk || !sugar || !temp || !ice) {
                    console.error('Missing selections:', { milk, sugar, temp, ice });
                    return;
                }

                var customizationsArray = [];
                if (milk.value !== 'none') customizationsArray.push(milk.value.charAt(0).toUpperCase() + milk.value.slice(1) + ' Milk');
                customizationsArray.push(sugar.value + ' Sugar');
                customizationsArray.push(temp.value.charAt(0).toUpperCase() + temp.value.slice(1));
                if (temp.value === 'cold') customizationsArray.push(ice.value.charAt(0).toUpperCase() + ice.value.slice(1));
                toppings.forEach(function(t) { customizationsArray.push(t.value.charAt(0).toUpperCase() + t.value.slice(1)); });

                var cart = JSON.parse(localStorage.getItem('cart') || '[]');
                for (var i = 0; i < itemQty; i++) {
                    cart.push({
                        name: currentItem.name,
                        price: parseFloat((currentItem.price + toppings_amount).toFixed(2)),
                        customizations: customizationsArray.join(', ')
                    });
                }
                localStorage.setItem('cart', JSON.stringify(cart));
                updateCartCount();
                closeCustomize();
                alert('Added to cart!');
            }

            document.addEventListener('DOMContentLoaded', updateCartCount);
            </script>

        <script src="/Cashier/script.js"></script>
        <script src="/weather.js"></script>
    </body>
</html>